`timescale 1ns/1ps

module single_port_ram(
    input clk,
    input we,
    input [3:0] address,
    input [7:0] data_in,
    output reg [7:0] data_out
);

    // 16 locations, each 8 bits wide
    reg [7:0] memory [0:15];

    always @(posedge clk)
    begin
        if (we)
            memory[address] <= data_in;      // Write operation
        else
            data_out <= memory[address];     // Read operation
    end

endmodule
